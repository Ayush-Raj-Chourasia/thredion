# ── Thredion Engine — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.

# Database (SQLite by default — no setup needed)
DATABASE_URL=sqlite:///./thredion.db

# OpenAI API Key (for AI classification & summarization)
# Leave blank to use keyword-based fallback
OPENAI_API_KEY=

# Twilio WhatsApp (for bot integration)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Embedding Model: "sentence-transformers" or "openai"
EMBEDDING_MODEL=sentence-transformers

# Cognitive Thresholds
SIMILARITY_THRESHOLD=0.55
RESURFACING_THRESHOLD=0.60
MAX_CONNECTIONS=5

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
