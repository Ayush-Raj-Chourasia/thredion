# ── Thredion Engine — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.

# ── Database Configuration ────────────────────────────────────
# Option 1: Supabase (PostgreSQL) — Recommended for production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-api-key

# Option 2: Direct PostgreSQL URL (alternative to Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 3: SQLite (local development only)
# DATABASE_URL=sqlite:///./thredion.db

# ── OpenAI API Key ────────────────────────────────────────────
# For AI classification & summarization
# Leave blank to use keyword-based fallback (slower but free)
OPENAI_API_KEY=sk-...

# ── Groq Cloud LLM (FREE TIER) ────────────────────────────────
# Free alternative to OpenAI for fast inference
GROQ_API_KEY=

# ── Twilio WhatsApp Integration ───────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ── Render Deployment (Environment Variables) ────────────────
# These are auto-set by Render, but you can override:
# HOST=0.0.0.0
# PORT=8000

# ── Frontend URL (for CORS) ───────────────────────────────────
FRONTEND_URL=https://thredion.vercel.app

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY_HOURS=168

# ── Embedding Configuration ───────────────────────────────────
# Options: "sentence-transformers" (local) or "openai" (API-based)
EMBEDDING_MODEL=sentence-transformers

# ── Cognitive Thresholds ──────────────────────────────────────
SIMILARITY_THRESHOLD=0.55
RESURFACING_THRESHOLD=0.60
MAX_CONNECTIONS=5

# ── Video Processing ─────────────────────────────────────────
SHORT_VIDEO_MAX_DURATION=300
MEDIUM_VIDEO_MAX_DURATION=1800
WHISPER_MODEL_SIZE=base

