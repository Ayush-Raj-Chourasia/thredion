# Thredion Engine - Environment Configuration
# Copy this to .env.local and fill in your values

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./thredion.db
# For production: postgresql://user:password@host:5432/thredion

# ── OpenAI API (Optional, fallback) ─────────────────────
OPENAI_API_KEY=sk_...

# ── Groq Cloud LLM (FREE TIER - Recommended) ────────────
# Get free API key from: https://console.groq.com/
GROQ_API_KEY=gsk_...

# ── HuggingFace Inference (Optional) ────────────────────
# Get token from: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...
USE_HF_INFERENCE=false

# ── Azure Queue Storage (for async video jobs) ──────────
# Get connection string from Azure Portal → Storage Account → Access Keys
AZURE_QUEUE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_QUEUE_NAME=video-transcription-jobs

# ── Video Processing Configuration ─────────────────────
SHORT_VIDEO_MAX_DURATION=300      # 5 minutes in seconds
MEDIUM_VIDEO_MAX_DURATION=1800    # 30 minutes in seconds
WHISPER_MODEL_SIZE=base            # tiny|base|small|medium|large

# ── Twilio WhatsApp ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx...
TWILIO_AUTH_TOKEN=auth_token_xxx... 
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ── Authentication ────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY_HOURS=168          # 7 days
OTP_EXPIRY_MINUTES=5

# ── Embedding Configuration ───────────────────────────
EMBEDDING_MODEL=sentence-transformers
EMBEDDING_DIMENSION=384

# ── Cognitive Thresholds ──────────────────────────────
SIMILARITY_THRESHOLD=0.55
RESURFACING_THRESHOLD=0.60
MAX_CONNECTIONS=5

# ── Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
