NEXT_PUBLIC_API_URL=http://localhost:8000

# Twilio central webhook router for Vercel
# Point Twilio to: https://your-vercel-app.vercel.app/api/twilio/webhook
TWILIO_ROUTER_DEFAULT_NAME=thredion
TWILIO_ROUTER_DEFAULT_URL=https://thredion-api.azurewebsites.net/api/whatsapp/webhook
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_AUTH_TOKEN=
TWILIO_ROUTER_TIMEOUT_MS=12000
TWILIO_ROUTER_FALLBACK_REPLY=Sorry, the router could not reach the selected project right now.

# Optional: add more projects and route by message prefix, e.g. [project-b] hello
# TWILIO_ROUTER_TARGETS_JSON=[{"name":"thredion","url":"https://thredion-api.azurewebsites.net/api/whatsapp/webhook","aliases":["main","default"]},{"name":"project-b","url":"https://project-b.example.com/api/twilio/webhook"}]